apiVersion: batch/v1
kind: Job
metadata:
  name: watch-agent
  namespace: watch-stress
spec:
  parallelism: __REPLICAS__
  completions: __REPLICAS__
  backoffLimit: 10000
  ttlSecondsAfterFinished: 600
  template:
    metadata:
      labels:
        app: watch-agent
        run-id: "__RUN_ID__"
    spec:
      serviceAccountName: watch-agent
      terminationGracePeriodSeconds: 5
      restartPolicy: Never
      containers:
        - name: watch-agent
          image: __IMAGE__
          args:
            - "--connections=__CONNS_PER_POD__"
            - "--duration=__DURATION__"
            - "--stagger=__STAGGER__"
            - "--resource-type=__RESOURCE_TYPE__"
            - "--namespace=__STRESS_NAMESPACE__"
            - "--spread-count=__SPREAD_COUNT__"
            - "--qps=1000000"
            - "--burst=1000000"
          env:
            - name: POD_NAME
              valueFrom:
                fieldRef:
                  fieldPath: metadata.name
            - name: RUN_ID
              value: "__RUN_ID__"
            - name: RESULTS_NAMESPACE
              value: "watch-stress"
          resources:
            requests:
              cpu: 25m
              memory: 64Mi
            limits:
              memory: 8Gi
